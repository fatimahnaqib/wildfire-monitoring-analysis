# Copy to `.env` and customize. `.env` is gitignored.

# Shared API key for protected FastAPI endpoints.
# Use a long random value (at least 32 chars).
WILDFIRE_API_KEY=change-me

# NASA FIRMS map key (do not commit real values to git)
FIRMS_MAP_KEY=change-me

# PostgreSQL (used by services + Airflow metadata DB name)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=change-me-too
AIRFLOW_DB=airflowdb

# Optional: enforce TLS to Postgres (require / verify-full / verify-ca). Leave unset for default local dev.
# POSTGRES_SSLMODE=require
# POSTGRES_SSL_ROOT_CERT=/path/to/ca.pem
# POSTGRES_SSL_CERT=  # client cert for mTLS, if required
# POSTGRES_SSL_KEY=

# Optional: append to Airflow metadata SQLAlchemy URL (e.g. ?sslmode=require). Use when the DB enforces SSL.
# AIRFLOW_SQLALCHEMY_CONN_SUFFIX=?sslmode=require

# Optional: secured Kafka (set when brokers use SSL or SASL_SSL). Paths are inside the container or mounted volumes.
# KAFKA_SECURITY_PROTOCOL=SASL_SSL
# KAFKA_SSL_CA_LOCATION=/certs/ca.pem
# KAFKA_SASL_MECHANISMS=SCRAM-SHA-256
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=

# When TLS terminates in front of the map app, set the public base URL to https://... so generated HTML and tile URLs are correct.
# MAP_PUBLIC_BASE_URL=https://map.example.com

# Optional: if 8002 is taken
CONSUMER_API_PORT=8002

# Optional: if you already have Postgres on 5432
POSTGRES_HOST_PORT=5432

# Airflow bootstrap admin user (used by airflow-init)
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_ADMIN_PASSWORD=change-me-too

# ---------------------------------------------------------
# Optional: HA Postgres overlay (`docker-compose.ha.yml`)
# ---------------------------------------------------------
POSTGRESQL_POSTGRES_PASSWORD=change-me-superuser
REPMGR_USERNAME=repmgr
REPMGR_PASSWORD=change-me-repmgr
# REPMGR_DATABASE=repmgr

PGPOOL_ADMIN_USERNAME=pgpooladmin
PGPOOL_ADMIN_PASSWORD=change-me-pgpool
