# Copy to .env for local public demo:
#   cp env.demo.example .env

POSTGRES_USER=airflow
POSTGRES_PASSWORD=change-me-demo-db
POSTGRES_HOST_PORT=5433

# NASA FIRMS key (required for POST /demo/sync; placeholder OK for read-only)
FIRMS_MAP_KEY=your-nasa-firms-map-key

# Public URL of this service (OSM tile proxy Referer; set to your ALB/domain in AWS)
MAP_PUBLIC_BASE_URL=http://localhost:8003

DEMO_API_PORT=8003
MAP_LOOKBACK_DAYS=30
MAP_MAX_RECORDS=5000

# Optional: protect POST /demo/sync and POST /generate
AUTH_ENABLED=false
WILDFIRE_API_KEY=

LOG_LEVEL=INFO
